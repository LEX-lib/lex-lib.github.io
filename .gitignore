.DS_Store
.idea
node_modules/
dist/
# TLS/SSL certificates and private keys — never commit
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx

# Exclude ALL .env files to prevent credential leaks
.env
.env.local
.env.development
.env.production
.env.test
.env.*.local
# Allow example/template env files to be committed
!.env.example
!.env.template
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
coverage/
.vscode/
*.sublime-workspace
*.sublime-project
# Mac system files
Thumbs.db
# Optional: ignore lock files
package-lock.json
yarn.lock
pnpm-lock.yaml
# Optional: ignore build cache
.cache/
# Optional: ignore test output
# Note: *.spec.ts and *.test.ts intentionally NOT ignored — test files must be tracked in git
# Optional: ignore output from Vite
vite.svg

# User-defined files
local.jsonc
